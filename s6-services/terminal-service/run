#!/command/with-contenv sh

# Generate auth token if not exists
if [ -z "$CANVAS_TERMINAL_TOKEN" ]; then
  export CANVAS_TERMINAL_TOKEN=$(cat /dev/urandom | tr -dc 'a-zA-Z0-9' | fold -w 64 | head -n 1)
  echo "[Terminal Service] Generated auth token"
fi

# Ensure socket directory exists
mkdir -p /tmp

# Start terminal service
cd /app
exec node server/terminal-service.ts
