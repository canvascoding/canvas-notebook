# App Configuration
NODE_ENV=development
PORT=3001
HOSTNAME=localhost
BASE_URL=http://localhost:3001

# Auth configuration (better-auth)
# Generate a secret: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001
# Optional: App admin credentials for seeding or tests
APP_USERNAME=admin
APP_PASSWORD=
APP_PASSWORD_HASH=

# Session configuration
SESSION_SECRET=
SESSION_SECURE_COOKIES=false

# SSH / SFTP Configuration
SSH_HOST=ssh.canvas.holdings
SSH_PORT=22
SSH_USER=canvas-notebook
SSH_PASSWORD=
SSH_KEY_PATH=
# Use local file system instead of SSH for storage/terminal
SSH_USE_LOCAL_FS=true
# Base path for workspace files
SSH_BASE_PATH=/home/canvas-notebook/workspace
# Enable test mode for SSH connections
SSH_TEST_MODE=0

# SSH Connection Pool
SSH_POOL_MIN=0
SSH_POOL_MAX=5
SSH_POOL_IDLE_TIMEOUT=600000

# Terminal Configuration
TERMINAL_IDLE_TIMEOUT=1800000
MAX_TERMINALS_PER_USER=3
SHELL=/bin/bash

# Media & Previews
MEDIA_CACHE_PATH=/tmp/canvas-media-cache
FFMPEG_PATH=ffmpeg

# AI Models (Optional configuration for CLIs)
# CLAUDE_API_KEY=
# GEMINI_API_KEY=
# OPENAI_API_KEY= (for Codex)
