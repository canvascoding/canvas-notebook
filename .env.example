# App Configuration
NODE_ENV=development
PORT=3000
HOSTNAME=localhost
BASE_URL=http://localhost:3000

# Auth configuration (better-auth)
# Generate a secret: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Preferred Better Auth base URL variable
BETTER_AUTH_BASE_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
# Optional: App admin credentials for seeding or tests
APP_USERNAME=admin
APP_PASSWORD=
APP_PASSWORD_HASH=

# Session configuration
SESSION_SECRET=
SESSION_SECURE_COOKIES=false

# Workspace Configuration
# Keep this folder inside the repository by default.
WORKSPACE_DIR=./workspace

# Terminal Configuration
TERMINAL_IDLE_TIMEOUT=1800000
MAX_TERMINALS_PER_USER=3
SHELL=/bin/bash

# Media & Previews
MEDIA_CACHE_PATH=/tmp/canvas-media-cache
FFMPEG_PATH=ffmpeg

# AI Models (Optional configuration for CLIs)
# CLAUDE_API_KEY=
# GEMINI_API_KEY=
# OPENAI_API_KEY= (for Codex)
