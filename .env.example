# App Configuration
NODE_ENV=development
PORT=3000
# Use localhost for local dev; use 0.0.0.0 in Docker containers.
HOSTNAME=localhost
BASE_URL=http://localhost:3000

# Auth configuration (better-auth)
# Generate a secret: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
# Required for callbacks/redirects
BETTER_AUTH_BASE_URL=http://localhost:3000
# Enable only for initial onboarding, then set back to false
ALLOW_SIGNUP=false
# Optional one-time bootstrap admin on startup
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=admin
BOOTSTRAP_ADMIN_NAME=Administrator

# Workspace Configuration
# Keep app data in ./data by default.
WORKSPACE_DIR=/data/workspace
SQLITE_PATH=/data/sqlite.db

# Terminal Configuration
TERMINAL_IDLE_TIMEOUT=1800000
MAX_TERMINALS_PER_USER=3
SHELL=/bin/bash

# Media & Previews
MEDIA_CACHE_PATH=/tmp/canvas-media-cache
FFMPEG_PATH=ffmpeg

# AI Models (optional; exposed to spawned terminal sessions)
# CLAUDE_API_KEY=
# GEMINI_API_KEY=
# OPENAI_API_KEY= (for Codex)

# Integration Settings (VEO / Nano Banana)
# Storage path for settings created via /settings
INTEGRATIONS_ENV_PATH=/home/node/canvas-integrations.env
# Optional master key for encrypted values at rest in INTEGRATIONS_ENV_PATH
# INTEGRATIONS_ENV_MASTER_KEY=change-me
