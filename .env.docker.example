# App Configuration
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0
BASE_URL=http://localhost:3456
BETTER_AUTH_BASE_URL=http://localhost:3456
# BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000, ...

# Auth configuration (better-auth)
BETTER_AUTH_SECRET=your-secret-genereate-please
CANVAS_INTERNAL_API_KEY=your-secret-genereate-please
# Set to true to show the provider onboarding wizard after login.
# This does not enable public signup.
ONBOARDING=true

# Single app user, created or synchronized on every startup
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=admin
BOOTSTRAP_ADMIN_NAME=Administrator

# Workspace Configuration - DO NOT CHANGE
# Base path for all app data (workspace, sqlite.db, skills, etc.)
DATA=/data
QMD_ENABLED=false

# Bei Start Ollama, Claude Code, Codex mit installieren
OLLAMA_CLI_AUTO_INSTALL=false
AI_CLI_AUTO_INSTALL=false

# Not required - only for testing
SENTRY_AUTH_TOKEN=
SENTRY_DSN=

# Logging Configuration
# LOG_LEVEL: off | error | warn | info | debug (default: info in production)
LOG_LEVEL=info
# LOG_TO_STDOUT: true | false (default: true in dev, false in production)
LOG_TO_STDOUT=true
# LOG_FILE: Custom log file path (default: /data/logs/runtime.log in production)
# LOG_FILE=/data/logs/runtime.log
