# App Configuration
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0
BASE_URL=http://localhost:3456
BETTER_AUTH_BASE_URL=http://localhost:3456
# BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000, ...

# Auth configuration (better-auth)
BETTER_AUTH_SECRET=your-secret-genereate-please
CANVAS_INTERNAL_API_KEY=your-secret-genereate-please

# Open the app and create the admin account in the first-run setup UI.
# On Linux installs, you can also pass ADMIN_EMAIL and ADMIN_PASSWORD to install.sh once.

# Workspace Configuration - DO NOT CHANGE
# Base path for all app data (workspace, sqlite.db, skills, etc.)
DATA=/data
QMD_ENABLED=false

# Database provider
# sqlite is the single-user default. Team, RAG, and collaboration installs require postgres.
CANVAS_DEPLOYMENT_MODE=single_user
CANVAS_DATABASE_PROVIDER=sqlite
# npm run setup enables the postgres Compose profile automatically when postgres/team mode is configured.
# For direct docker compose commands, set COMPOSE_PROFILES=postgres or run with --profile postgres.
# COMPOSE_PROFILES=postgres
# DATABASE_URL=postgresql://canvas:change-me@postgres:5432/canvas_notebook
CANVAS_POSTGRES_VECTOR_ENABLED=false
CANVAS_POSTGRES_IMAGE=pgvector/pgvector:0.8.3-pg18
CANVAS_POSTGRES_DATA_VOLUME=canvas-postgres-data
CANVAS_POSTGRES_DB=canvas_notebook
CANVAS_POSTGRES_USER=canvas
# CANVAS_POSTGRES_PASSWORD=change-me

# License service
# Defaults to https://api.canvasnotebook.app when unset.
# CANVAS_LICENSE_CONTROL_PLANE_URL=https://api.canvasnotebook.app
# Managed services Control Plane API
# Defaults to https://api.canvasnotebook.app when managed services are enabled and unset.
# CANVAS_CONTROL_PLANE_URL=https://api.canvasnotebook.app
# Optional override/pin for offline or rotated license verification.
# CANVAS_LICENSE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# CANVAS_LICENSE_TRUSTED_PUBLIC_KEY_FINGERPRINTS=sha256_hex_fingerprint

# Bei Start Ollama, Claude Code, Codex mit installieren
OLLAMA_CLI_AUTO_INSTALL=false
AI_CLI_AUTO_INSTALL=false

# Onboarding wizard (first-run setup: language, license, AI provider)
# Set to true to enable the onboarding wizard after initial setup.
# ONBOARDING=true

# Onboarding hints (contextual tooltip tour that guides users through the UI)
# Set to true to enable the guided tour hints. Defaults to false.
# ONBOARDING_HINTS=false

# Not required - only for testing
SENTRY_AUTH_TOKEN=
SENTRY_DSN=

# Logging Configuration
# LOG_LEVEL: off | error | warn | info | debug (default: info in production)
LOG_LEVEL=info
# LOG_TO_STDOUT: true | false (default: true in dev, false in production)
LOG_TO_STDOUT=false
# LOG_FILE: Custom log file path (default: /data/logs/runtime.log in production)
# LOG_FILE=/data/logs/runtime.log
