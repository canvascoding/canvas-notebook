#!/usr/bin/env bash
set -euo pipefail

CANVAS_CLI_VERSION="2026.5.29.1"
INSTALL_DIR="${CANVAS_INSTALL_DIR:-/opt/canvas-notebook}"
COMPOSE_FILE="${CANVAS_COMPOSE_FILE:-${INSTALL_DIR}/canvas-notebook-compose.yaml}"
DATA_DIR="${CANVAS_DATA_DIR:-${HOME:-/opt}/canvas-notebook-data}"
CANVAS_SWAP_ENABLED="${CANVAS_SWAP_ENABLED:-true}"
CANVAS_SWAP_SIZE="${CANVAS_SWAP_SIZE:-2G}"
CANVAS_SWAP_FILE="${CANVAS_SWAP_FILE:-/swapfile}"
SERVICE="${CANVAS_SERVICE:-canvas-notebook}"
IMAGE_REF="${CANVAS_IMAGE:-ghcr.io/canvascoding/canvas-notebook:latest}"
INSTALL_SCRIPT_URL="https://raw.githubusercontent.com/canvascoding/canvas-notebook/main/install.sh"

SHARED_DIR=""
CLI_BIN_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")" 2>/dev/null && pwd)"
for _dir in "${CLI_BIN_DIR}/../lib/shared" "${INSTALL_DIR}/lib/shared"; do
  if [[ -f "${_dir}/output.sh" ]]; then
    SHARED_DIR="$_dir"
    break
  fi
done
unset _dir

if [[ -n "$SHARED_DIR" ]]; then
  for _lib in output utils config_json logging compose caddy swap container docker ui; do
    if [[ -f "${SHARED_DIR}/${_lib}.sh" ]]; then
      # shellcheck source=/dev/null
      . "${SHARED_DIR}/${_lib}.sh"
    fi
  done
  unset _lib
  _systemd_lib="${CLI_BIN_DIR}/../lib/systemd.sh"
  if [[ ! -f "$_systemd_lib" ]]; then
    _systemd_lib="${INSTALL_DIR}/lib/systemd.sh"
  fi
  if [[ -f "$_systemd_lib" ]]; then
    # shellcheck source=/dev/null
    . "$_systemd_lib"
  fi
  unset _systemd_lib

  _fix_config_perms() {
    [[ "$(id -u)" -eq 0 ]] && return 0
    local _owner _cfg_files _cfg_dirs _f _d
    _owner="$(_install_user)"
    _cfg_files=("$CONFIG_JSON_PATH" "$CONFIG_ENV_PATH" "$COMPOSE_ENV_PATH" "$COMPOSE_FILE")
    for _f in "${_cfg_files[@]}"; do
      if [[ -f "$_f" ]] && [[ ! -r "$_f" ]]; then
        run_root chown "$_owner" "$_f" 2>/dev/null || true
        run_root chmod 644 "$_f" 2>/dev/null || true
      fi
    done
    _cfg_dirs=("$(dirname "$CONFIG_JSON_PATH")" "${INSTALL_DIR}/lib/shared" "${INSTALL_DIR}/lib/commands" "${INSTALL_DIR}/templates")
    for _d in "${_cfg_dirs[@]}"; do
      if [[ -d "$_d" ]] && [[ ! -w "$_d" ]]; then
        run_root chown "$_owner" "$_d" 2>/dev/null || true
        run_root chmod 755 "$_d" 2>/dev/null || true
      fi
    done
    if [[ -d "${INSTALL_DIR}/lib/shared" ]] && [[ ! -r "${INSTALL_DIR}/lib/shared/config_json.sh" ]]; then
      for _f in "${INSTALL_DIR}/lib/shared/"*.sh; do
        run_root chown "$_owner" "$_f" 2>/dev/null || true
        run_root chmod 644 "$_f" 2>/dev/null || true
      done
    fi
    if [[ -d "${INSTALL_DIR}/lib/commands" ]] && [[ ! -r "${INSTALL_DIR}/lib/commands/caddy.sh" ]]; then
      for _f in "${INSTALL_DIR}/lib/commands/"*.sh; do
        run_root chown "$_owner" "$_f" 2>/dev/null || true
        run_root chmod 644 "$_f" 2>/dev/null || true
      done
    fi
    for _f in "${_cfg_files[@]}"; do
      if [[ -f "$_f" ]] && [[ ! -r "$_f" ]]; then
        printf '✗ Permission denied: %s\n' "$_f" >&2
        printf '  Run with sudo or fix ownership: sudo chown %s %s\n' "$_owner" "$_f" >&2
        exit 1
      fi
    done
  }
  _fix_config_perms
  unset -f _fix_config_perms
else
  printf '✗ Canvas Notebook shared libraries not found.\n' >&2
  printf '  Run: canvas-notebook cli-update\n' >&2
  exit 1
fi

OUTPUT_JSON=false
NO_BANNER=false
for _arg in "$@"; do
  case "$_arg" in
    --json)
      OUTPUT_JSON=true
      NO_BANNER=true
      ;;
    --no-banner)
      NO_BANNER=true
      ;;
  esac
done
unset _arg

config_json_init

DEFAULT_HEALTH_ATTEMPTS="${CANVAS_HEALTH_MAX_ATTEMPTS:-180}"
LOG_DIR="${CANVAS_MANAGER_LOG_DIR:-/var/log/canvas-notebook}"
LOG_FILE="${LOG_DIR}/manager.log"
CANVAS_AUTO_UPDATE_ENABLED="${CANVAS_AUTO_UPDATE_ENABLED:-true}"
CANVAS_AUTO_UPDATE_SCHEDULE="${CANVAS_AUTO_UPDATE_SCHEDULE:-*-*-* 04:00:00}"

cmd="${1:-help}"
if [[ "$#" -gt 0 ]]; then
  shift
fi

CMD_ARGS=()
while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --json)
      OUTPUT_JSON=true
      NO_BANNER=true
      shift
      ;;
    --no-banner)
      NO_BANNER=true
      shift
      ;;
    -V|--version)
      if [[ "$OUTPUT_JSON" == "true" ]]; then
        image_build_json "$IMAGE_REF" "$(container_id)"
      else
        print_build_info "$IMAGE_REF" "$(container_id)"
      fi
      exit 0
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      CMD_ARGS+=("$@")
      break
      ;;
    *)
      CMD_ARGS+=("$1")
      shift
      ;;
  esac
done

case "$cmd" in
  help|-h|--help)
    usage
    exit 0
    ;;
  version|-V|--version)
    if [[ "$OUTPUT_JSON" == "true" ]]; then
      image_build_json "$IMAGE_REF" "$(container_id)"
    else
      print_build_info "$IMAGE_REF" "$(container_id)"
    fi
    exit 0
    ;;
esac

declare -A CMD_FILE=(
  [install]=update       [update]=update
  [start]=lifecycle      [restart]=lifecycle  [stop]=lifecycle  [down]=lifecycle
  [status]=status        [health]=status      [diagnose]=status [config]=status [ps]=status
  [logs]=logs           [container-logs]=logs [manager-log]=logs [cleanup-logs]=logs
  [env]=env
  [swap]=swap           [swap-enable]=swap   [swap-disable]=swap
  [caddy]=caddy         [caddy-reload]=caddy [caddy-fix]=caddy
  [auto-update-status]=auto_update [auto-update-enable]=auto_update [auto-update-disable]=auto_update [auto-update-sync]=auto_update
  [cli-update]=cli_update
  [config-show]=config_cmd [config-set]=config_cmd [config-migrate]=config_cmd
)

if [[ -z "${CMD_FILE[$cmd]:-}" ]]; then
  usage >&2
  exit 2
fi

if [[ "$NO_BANNER" != "true" ]]; then
  banner
fi

CMD_DIR="${CLI_BIN_DIR}/../lib/commands"
if [[ ! -d "$CMD_DIR" ]]; then
  CMD_DIR="${INSTALL_DIR}/lib/commands"
fi

if [[ -f "${CMD_DIR}/${CMD_FILE[$cmd]}.sh" ]]; then
  # shellcheck source=/dev/null
  . "${CMD_DIR}/${CMD_FILE[$cmd]}.sh"
else
  fail "Command file not found: ${CMD_DIR}/${CMD_FILE[$cmd]}.sh. Run: canvas-notebook cli-update"
fi

cmd_fn="cmd_${cmd//-/_}"

if ! declare -f "$cmd_fn" >/dev/null 2>&1; then
  fail "Command '${cmd}' is defined in ${CMD_FILE[$cmd]}.sh but function ${cmd_fn}() not found"
fi

"$cmd_fn" "${CMD_ARGS[@]}"
