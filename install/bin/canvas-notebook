#!/usr/bin/env bash
set -euo pipefail

INSTALL_DIR="${CANVAS_INSTALL_DIR:-/opt/canvas-notebook}"
COMPOSE_FILE="${CANVAS_COMPOSE_FILE:-${INSTALL_DIR}/canvas-notebook-compose.yaml}"
DATA_DIR="${CANVAS_DATA_DIR:-${HOME:-/opt}/canvas-notebook-data}"
CANVAS_SWAP_ENABLED="${CANVAS_SWAP_ENABLED:-false}"
CANVAS_SWAP_SIZE="${CANVAS_SWAP_SIZE:-2G}"
CANVAS_SWAP_FILE="${CANVAS_SWAP_FILE:-/swapfile}"
SERVICE="${CANVAS_SERVICE:-canvas-notebook}"
IMAGE_REF="${CANVAS_IMAGE:-ghcr.io/canvascoding/canvas-notebook:latest}"
INSTALL_SCRIPT_URL="https://raw.githubusercontent.com/canvascoding/canvas-notebook/main/install.sh"
CONFIG_FILE="${CANVAS_MANAGER_CONFIG:-/etc/canvas-notebook/manager.env}"

SHARED_DIR=""
CLI_BIN_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")" 2>/dev/null && pwd)"
for _dir in "${CLI_BIN_DIR}/../lib/shared" "${INSTALL_DIR}/lib/shared"; do
  if [[ -f "${_dir}/output.sh" ]]; then
    SHARED_DIR="$_dir"
    break
  fi
done
unset _dir

if [[ -n "$SHARED_DIR" ]]; then
  for _lib in output utils config logging compose caddy swap container docker ui; do
    if [[ -f "${SHARED_DIR}/${_lib}.sh" ]]; then
      # shellcheck source=/dev/null
      . "${SHARED_DIR}/${_lib}.sh"
    fi
  done
  unset _lib
else
  printf '✗ Canvas Notebook shared libraries not found.\n' >&2
  printf '  Run: canvas-notebook cli-update\n' >&2
  exit 1
fi

load_manager_config "$CONFIG_FILE"

DEFAULT_HEALTH_ATTEMPTS="${CANVAS_HEALTH_MAX_ATTEMPTS:-180}"
LOG_DIR="${CANVAS_MANAGER_LOG_DIR:-/var/log/canvas-notebook}"
LOG_FILE="${LOG_DIR}/manager.log"
CANVAS_AUTO_UPDATE_ENABLED="${CANVAS_AUTO_UPDATE_ENABLED:-true}"
CANVAS_AUTO_UPDATE_SCHEDULE="${CANVAS_AUTO_UPDATE_SCHEDULE:-*-*-* 04:00:00}"

cmd="${1:-help}"
if [[ "$#" -gt 0 ]]; then
  shift
fi

OUTPUT_JSON=false
NO_BANNER=false
while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --json)
      OUTPUT_JSON=true
      NO_BANNER=true
      ;;
    --no-banner)
      NO_BANNER=true
      ;;
    -V|--version)
      printf 'Canvas Notebook CLI %s\n' "$CANVAS_CLI_VERSION"
      exit 0
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      fail "Unknown option: $1"
      ;;
  esac
  shift
done

declare -A CMD_FILE=(
  [install]=update       [update]=update
  [start]=lifecycle      [restart]=lifecycle  [stop]=lifecycle  [down]=lifecycle
  [status]=status        [health]=status      [diagnose]=status [config]=status [ps]=status
  [logs]=logs           [container-logs]=logs [manager-log]=logs [cleanup-logs]=logs
  [env]=env
  [swap]=swap           [swap-enable]=swap   [swap-disable]=swap
  [caddy]=caddy         [caddy-reload]=caddy [caddy-fix]=caddy
  [auto-update-status]=auto_update [auto-update-enable]=auto_update [auto-update-disable]=auto_update
  [cli-update]=cli_update
  [help]=help [version]=version
)

case "$cmd" in
  help|-h|--help)
    usage
    exit 0
    ;;
  version|-V|--version)
    printf 'Canvas Notebook CLI %s\n' "$CANVAS_CLI_VERSION"
    exit 0
    ;;
esac

if [[ -z "${CMD_FILE[$cmd]:-}" ]]; then
  usage >&2
  exit 2
fi

if [[ "$NO_BANNER" != "true" ]]; then
  banner
fi

CMD_DIR="${CLI_BIN_DIR}/../lib/commands"
if [[ ! -d "$CMD_DIR" ]]; then
  CMD_DIR="${INSTALL_DIR}/lib/commands"
fi

if [[ -f "${CMD_DIR}/${CMD_FILE[$cmd]}.sh" ]]; then
  # shellcheck source=/dev/null
  . "${CMD_DIR}/${CMD_FILE[$cmd]}.sh"
else
  fail "Command file not found: ${CMD_DIR}/${CMD_FILE[$cmd]}.sh. Run: canvas-notebook cli-update"
fi

cmd_fn="cmd_${cmd//-/_}"

if ! declare -f "$cmd_fn" >/dev/null 2>&1; then
  fail "Command '${cmd}' is defined in ${CMD_FILE[$cmd]}.sh but function ${cmd_fn}() not found"
fi

"$cmd_fn" "$@"