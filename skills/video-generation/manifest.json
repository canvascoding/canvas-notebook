{
  "name": "video-generation",
  "version": "1.0.0",
  "title": "Videos mit VEO generieren",
  "description": "Generiert Videos mit Google VEO über den lokalen Canvas-Wrapper. Verwenden wenn der User sagt: erstelle ein Video, generiere ein Video, mache ein Video von..., create a video, generate a video. Output: workspace/veo-studio/video-generation/. Der Gemini-Key wird zentral aus den Integrations-Einstellungen geladen; kein manuelles Env-Loading nötig. Hinweis: Dauert typischerweise 3-10 Minuten.",
  "type": "cli",
  "author": "system",
  "created_at": "2025-01-15T00:00:00Z",
  "tool": {
    "name": "video_generation",
    "description": "Generiert Videos mit Google VEO",
    "parameters": {
      "prompt": {
        "type": "string",
        "required": true,
        "description": "Beschreibung des zu generierenden Videos"
      },
      "mode": {
        "type": "string",
        "enum": ["text_to_video", "frames_to_video", "references_to_video", "extend_video"],
        "default": "text_to_video",
        "description": "Generierungsmodus"
      },
      "aspect_ratio": {
        "type": "string",
        "enum": ["16:9", "9:16"],
        "default": "16:9",
        "description": "Seitenverhältnis des Videos"
      },
      "resolution": {
        "type": "string",
        "enum": ["720p", "1080p", "4k"],
        "default": "720p",
        "description": "Videoauflösung"
      },
      "start_frame": {
        "type": "string",
        "required": false,
        "description": "Pfad zum Startbild (für frames_to_video Modus)"
      },
      "end_frame": {
        "type": "string",
        "required": false,
        "description": "Pfad zum Endbild (für frames_to_video Modus)"
      },
      "input_video": {
        "type": "string",
        "required": false,
        "description": "Pfad zum Eingangsvideo (für extend_video Modus)"
      }
    }
  },
  "handler": {
    "type": "cli",
    "command": "video-generation"
  }
}
