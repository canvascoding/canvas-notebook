#!/usr/bin/env bash
set -euo pipefail

# ---------------------------------------------------------------------------
# Canvas Skills CLI
# Runs Canvas Notebook local skill services without internal API hops.
# Usage: /data/skills/skill <skill-name> [options...]
# ---------------------------------------------------------------------------

# JSON string escaping via Python3 (available in all Node.js Docker images)
json_str() {
  printf '%s' "$1" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))'
}

resolve_app_root() {
  local script_dir
  script_dir="$(cd "$(dirname "$0")" && pwd)"

  if [ -n "${CANVAS_APP_ROOT:-}" ] && [ -x "${CANVAS_APP_ROOT}/node_modules/.bin/tsx" ] && [ -f "${CANVAS_APP_ROOT}/scripts/run-local-skill.ts" ]; then
    printf '%s\n' "$CANVAS_APP_ROOT"
    return 0
  fi

  if [ -x "/app/node_modules/.bin/tsx" ] && [ -f "/app/scripts/run-local-skill.ts" ]; then
    printf '%s\n' "/app"
    return 0
  fi

  if [ -x "$(pwd)/node_modules/.bin/tsx" ] && [ -f "$(pwd)/scripts/run-local-skill.ts" ]; then
    printf '%s\n' "$(pwd)"
    return 0
  fi

  if [ -x "${script_dir}/../node_modules/.bin/tsx" ] && [ -f "${script_dir}/../scripts/run-local-skill.ts" ]; then
    printf '%s\n' "${script_dir}/.."
    return 0
  fi

  return 1
}

run_local_skill() {
  local skill="$1"
  local payload="$2"
  local app_root

  app_root="$(resolve_app_root)" || {
    echo "ERROR: Could not locate Canvas Notebook app root for local skill execution." >&2
    echo "Set CANVAS_APP_ROOT or run from the repository root." >&2
    exit 1
  }

  "${app_root}/node_modules/.bin/tsx" "${app_root}/scripts/run-local-skill.ts" "$skill" "$payload"
}

# ---------------------------------------------------------------------------
# Skill dispatcher
# ---------------------------------------------------------------------------
SKILL="${1:-}"
if [ -z "$SKILL" ]; then
  echo "Canvas Skills CLI" >&2
  echo "" >&2
  echo "Usage: skill <skill-name> [options]" >&2
  echo "" >&2
  echo "Available skills:" >&2
  echo "  image-generation   Generate images with Gemini" >&2
  echo "  video-generation   Generate videos with Google VEO" >&2
  echo "  ad-localization    Localize ad images for target markets (Nano Banana)" >&2
  echo "  qmd                Search markdown notes and docs in workspace" >&2
  echo "" >&2
  echo "For skill-specific help, see /data/skills/<skill-name>/README.md" >&2
  exit 1
fi
shift

case "$SKILL" in

  # -------------------------------------------------------------------------
  image-generation|image-gen|img)
    PROMPT=""
    MODEL="gemini-3.1-flash-image-preview"
    ASPECT_RATIO="1:1"
    COUNT=1
    REF_LIST=""

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --prompt|-p)       PROMPT="$2";        shift 2 ;;
        --model|-m)        MODEL="$2";         shift 2 ;;
        --aspect-ratio|-a) ASPECT_RATIO="$2";  shift 2 ;;
        --count|-n)        COUNT="$2";         shift 2 ;;
        --ref|-r)
          REF_LIST="${REF_LIST:+$REF_LIST,}$(json_str "$2")"
          shift 2 ;;
        *) echo "Unknown option: $1" >&2; exit 1 ;;
      esac
    done

    REFS="[${REF_LIST}]"
    run_local_skill "image-generation" \
      "{\"prompt\":$(json_str "$PROMPT"),\"model\":$(json_str "$MODEL"),\"aspectRatio\":$(json_str "$ASPECT_RATIO"),\"imageCount\":$COUNT,\"referenceImagePaths\":$REFS}"
    echo
    ;;

  # -------------------------------------------------------------------------
  video-generation|video-gen|veo)
    PROMPT=""
    MODEL="veo-3.1-fast-generate-preview"
    MODE="text_to_video"
    ASPECT_RATIO="16:9"
    RESOLUTION="720p"
    START_FRAME="null"
    END_FRAME="null"
    INPUT_VIDEO="null"
    REF_LIST=""

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --prompt|-p)       PROMPT="$2";                          shift 2 ;;
        --model|-m)        MODEL="$2";                           shift 2 ;;
        --mode)            MODE="$2";                            shift 2 ;;
        --aspect-ratio|-a) ASPECT_RATIO="$2";                    shift 2 ;;
        --resolution)      RESOLUTION="$2";                      shift 2 ;;
        --start-frame)     START_FRAME="$(json_str "$2")";       shift 2 ;;
        --end-frame)       END_FRAME="$(json_str "$2")";         shift 2 ;;
        --input-video)     INPUT_VIDEO="$(json_str "$2")";       shift 2 ;;
        --ref|-r)
          REF_LIST="${REF_LIST:+$REF_LIST,}$(json_str "$2")"
          shift 2 ;;
        *) echo "Unknown option: $1" >&2; exit 1 ;;
      esac
    done

    REFS="[${REF_LIST}]"
    echo "[skill] Starting video generation (this may take 3–10 minutes)..." >&2
    run_local_skill "video-generation" \
      "{\"prompt\":$(json_str "$PROMPT"),\"model\":$(json_str "$MODEL"),\"mode\":$(json_str "$MODE"),\"aspectRatio\":$(json_str "$ASPECT_RATIO"),\"resolution\":$(json_str "$RESOLUTION"),\"startFramePath\":$START_FRAME,\"endFramePath\":$END_FRAME,\"inputVideoPath\":$INPUT_VIDEO,\"referenceImagePaths\":$REFS}"
    echo
    ;;

  # -------------------------------------------------------------------------
  ad-localization|ad-loc|nano-banana)
    REF=""
    MARKETS_LIST=""
    ASPECT_RATIO="16:9"
    MODEL="gemini-3.1-flash-image-preview"
    INSTRUCTIONS=""

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --ref|-r)          REF="$2";           shift 2 ;;
        --market|-t)
          MARKETS_LIST="${MARKETS_LIST:+$MARKETS_LIST,}$(json_str "$2")"
          shift 2 ;;
        --aspect-ratio|-a) ASPECT_RATIO="$2";  shift 2 ;;
        --model|-m)        MODEL="$2";         shift 2 ;;
        --instructions|-i) INSTRUCTIONS="$2";  shift 2 ;;
        *) echo "Unknown option: $1" >&2; exit 1 ;;
      esac
    done

    run_local_skill "ad-localization" \
      "{\"referenceImagePath\":$(json_str "$REF"),\"targetMarkets\":[${MARKETS_LIST}],\"aspectRatio\":$(json_str "$ASPECT_RATIO"),\"model\":$(json_str "$MODEL"),\"customInstructions\":$(json_str "$INSTRUCTIONS")}"
    echo
    ;;

  # -------------------------------------------------------------------------
  qmd|markdown-search|search-notes)
    # qmd is a local CLI tool
    # Ensure qmd is in PATH
    export PATH="$HOME/.bun/bin:$PATH"
    
    if ! command -v qmd >/dev/null 2>&1; then
      echo "ERROR: qmd is not installed. Please wait for the container to finish setup." >&2
      exit 1
    fi
    
    # Pass all arguments directly to qmd
    qmd "$@"
    ;;

  *)
    echo "Unknown skill: $SKILL" >&2
    echo "Available: image-generation, video-generation, ad-localization, qmd" >&2
    exit 1
    ;;
esac
