# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Key material (NEVER commit these!)
*.key
*.pub
keys/

# Security-sensitive files
*.crt
*.csr
*.p12
*.pfx

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.docker
.env.docker.local
.env.development.local
.env.test.local
.env.production.local
!.env.example
!.env.docker.example

# vercel
.vercel

# AI Chat Screenshots
temp/screenshots/

# workspace data (keep directory, ignore content)
/workspace/*
!/workspace/.gitkeep
/data/*
!/data/.gitkeep
!/data/workspace/
/data/workspace/*
!/data/workspace/.gitkeep

# typescript
*.tsbuildinfo
next-env.d.ts

/docs

# Sentry Config File
.env.sentry-build-plugin

/data